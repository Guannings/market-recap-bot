# Copy this file to ".env" and fill in your values, then:  source .env
# (or set these as real environment variables / GitHub Actions secrets)

# The Gmail account that SENDS the email.
export GMAIL_ADDRESS="you@gmail.com"

# A Gmail *App Password* (16 chars, no spaces) — NOT your normal login password.
# How to get one:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create an App Password:      https://myaccount.google.com/apppasswords
#   3. Paste the 16-char code below (remove the spaces Google shows).
export GMAIL_APP_PASSWORD="abcdabcdabcdabcd"

# Who receives the recap. Comma-separated. Defaults to GMAIL_ADDRESS if omitted.
export RECIPIENTS="you@gmail.com"

# OPTIONAL: for a sharper, AI-written "What Happened Overnight" summary.
# If set, the bot asks Claude to write the recap narrative from the fetched data
# (no invented numbers). If left blank, a built-in rule-based summary is used.
# Get a key at https://console.anthropic.com  ->  paste it below.
# export ANTHROPIC_API_KEY="sk-ant-..."
